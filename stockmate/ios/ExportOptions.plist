<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- App Store Connect distribution + direct upload to TestFlight. -->
  <key>method</key>
  <string>app-store-connect</string>
  <key>destination</key>
  <string>upload</string>

  <!-- Apple Developer team. Automatic signing lets xcodebuild create the
       Apple Distribution cert + App Store profile on the fly (with
       -allowProvisioningUpdates). -->
  <key>teamID</key>
  <string>2LQG45M7VQ</string>
  <key>signingStyle</key>
  <string>automatic</string>

  <key>uploadSymbols</key>
  <true/>

  <!-- false = the build number from pubspec.yaml (+N) is authoritative.
       Set true to let App Store Connect auto-increment instead. -->
  <key>manageAppVersionAndBuildNumber</key>
  <false/>
</dict>
</plist>
